# N-CIIA Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Application ──────────────────────────────────────────────────────────────
NCIIA_ENVIRONMENT=development        # development | staging | production
NCIIA_VERSION=1.0.0

# ── API Server ────────────────────────────────────────────────────────────────
NCIIA_API_HOST=0.0.0.0
NCIIA_API_PORT=8000
NCIIA_API_DEBUG=false

# CORS: space-separated list of allowed origins (JSON array format)
# Example for production: NCIIA_API_CORS_ORIGINS=["https://nciia.yourdomain.com"]
NCIIA_API_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Optional API key for bearer-token protection.
# Leave blank for open access (development only).
NCIIA_API_API_KEY=

# Rate limiting — requests per window per client IP
NCIIA_API_RATE_LIMIT=100
NCIIA_API_RATE_WINDOW=60

# ── Database ──────────────────────────────────────────────────────────────────
NCIIA_DB_PATH=data/db/nciia.db

# ── LLM Integration ───────────────────────────────────────────────────────────
# Supported providers: ollama | openai | anthropic | groq
NCIIA_LLM_PROVIDER=groq
NCIIA_LLM_MODEL_NAME=llama3-8b-8192
NCIIA_LLM_API_BASE=https://api.groq.com/openai/v1
NCIIA_LLM_API_KEY=your_groq_api_key_here
NCIIA_LLM_MAX_TOKENS=2048
NCIIA_LLM_TEMPERATURE=0.1

# ── Logging ───────────────────────────────────────────────────────────────────
NCIIA_LOG_LEVEL=INFO
NCIIA_LOG_FORMAT=json                # json | console
NCIIA_LOG_FILE_PATH=logs/nciia.log

# ── OSINT Collection ──────────────────────────────────────────────────────────
NCIIA_OSINT_DEFAULT_INTERVAL_SECONDS=300
NCIIA_OSINT_MAX_CONCURRENT_WATCHERS=10

# ── Security ──────────────────────────────────────────────────────────────────
NCIIA_SECURITY_ENABLE_AUDIT_LOG=true
NCIIA_SECURITY_SESSION_TIMEOUT_MINUTES=60
